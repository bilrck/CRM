# 🚪 Server Configuration
PORT=3001
NODE_ENV=production
JWT_SECRET=your_jwt_secret_here
API_URL=https://api.seudominio.com
FRONTEND_URL=https://app.seudominio.com

# 🗄️ Database
DATABASE_URL="postgresql://user:password@localhost:5432/db_name?schema=public"

# 📧 SMTP Configuration (Recovery & Alerts)
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_USER=seu-usuario@exemplo.com
SMTP_PASS=sua-senha-secreta
SMTP_FROM='"Rastreia AI" <suporte@seudominio.com>'

# 🔑 Master Admin Key
MASTER_ADMIN_KEY=some_very_long_random_string

# 🏢 Seed Configuration (Initial setup only)
SEED_ADMIN_EMAIL=admin@seudominio.com
SEED_ADMIN_PASSWORD=change_this_immediately

# 📱 WhatsApp & Meta Integrations
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your_evolution_key

META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_WEBHOOK_VERIFY_TOKEN=your_webhook_token

# 🤖 AI Assistant
AI_DEFAULT_PROVIDER=google
AI_DEFAULT_MODEL=gemini-1.5-pro
AI_TEMPERATURE=0.7
